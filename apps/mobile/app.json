{
  "expo": {
    "name": "Genki",
    "slug": "genki",
    "owner": "tonynguyenbk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2ECC71"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.genki.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2ECC71"
      },
      "package": "com.genki.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Genki cần quyền truy cập camera để chụp ảnh bữa ăn"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Genki cần quyền truy cập thư viện ảnh"
        }
      ],
      "expo-asset"
    ],
    "scheme": "genki",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a07e9f89-9ae8-402e-ad67-cb2725f2057f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a07e9f89-9ae8-402e-ad67-cb2725f2057f"
    }
  }
}
